# Copy to .env and set your Anthropic API key.
# Used by Docker Compose; agents.sh uses the "key" file instead.
ANTHROPIC_API_KEY=sk-ant-api03-

# Web UI access token (agent-0). Default is "agent0". Use: http://localhost:32350/?token=agent0
# Set a custom token for production. Optional.
# CC_WEB_AUTH=agent0
