AGENT_BASE_PORT=3000
# AGENT_BASE_PORT_END must equal AGENT_BASE_PORT + 20 (docker-compose can't do math)
AGENT_BASE_PORT_END=3020
CC_WEB_AUTH=agent0

# Open WebUI
OPEN_WEBUI_PORT=3080
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=changeme

# VPS only (used by Caddy + Authelia)
AGENT_DOMAIN=agent.example.com
# Cloudflare API token for DNS challenge TLS certs (to use another provider, rebuild caddy/Dockerfile)
DNS_API_TOKEN=your-cloudflare-api-token
AUTHELIA_JWT_SECRET=generate-a-long-random-string
AUTHELIA_SESSION_SECRET=generate-another-long-random-string
AUTHELIA_STORAGE_ENCRYPTION_KEY=generate-a-32-char-hex-string

# Subagent ports for Caddy (AGENT_BASE_PORT + N). Update if you change AGENT_BASE_PORT.
AGENT_BASE_PORT_1=3001
AGENT_BASE_PORT_2=3002
AGENT_BASE_PORT_3=3003
AGENT_BASE_PORT_4=3004
AGENT_BASE_PORT_5=3005
AGENT_BASE_PORT_6=3006
AGENT_BASE_PORT_7=3007
AGENT_BASE_PORT_8=3008
AGENT_BASE_PORT_9=3009
AGENT_BASE_PORT_10=3010
AGENT_BASE_PORT_11=3011
AGENT_BASE_PORT_12=3012
AGENT_BASE_PORT_13=3013
AGENT_BASE_PORT_14=3014
AGENT_BASE_PORT_15=3015
AGENT_BASE_PORT_16=3016
AGENT_BASE_PORT_17=3017
AGENT_BASE_PORT_18=3018
AGENT_BASE_PORT_19=3019
AGENT_BASE_PORT_20=3020
