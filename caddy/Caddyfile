{
    email admin@{$AGENT_DOMAIN}
    acme_dns cloudflare {$DNS_API_TOKEN}
}

(authelia) {
    forward_auth http://authelia:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
}

# Authelia login UI
auth.{$AGENT_DOMAIN} {
    reverse_proxy authelia:9091
}

# Open WebUI (primary chat interface)
{$AGENT_DOMAIN} {
    import authelia
    reverse_proxy http://ordinal-webui:8080
}

# Claude Code Web (backup — full terminal/file access)
cc.{$AGENT_DOMAIN} {
    import authelia
    reverse_proxy http://ordinal-agent:{$AGENT_BASE_PORT}
}

