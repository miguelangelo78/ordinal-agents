FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    ca-certificates curl gnupg \
    git tmux wget jq unzip \
    python3 python3-pip python3-venv \
    build-essential sudo \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI (SDK)
RUN npm install -g @anthropic-ai/claude-code

# cc-bridge (copied during base image build via agents.sh build context)
COPY cc-bridge/ /opt/cc-bridge/
RUN cd /opt/cc-bridge && npm install --production

# Non-root user with sudo
RUN useradd -m -s /bin/bash claude \
    && usermod -aG sudo claude \
    && echo "claude ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

RUN mkdir -p /home/claude/workspace /home/claude/.claude \
    && chown -R claude:claude /home/claude

RUN su - claude -c "git config --global user.name 'subagent' && \
    git config --global user.email 'subagent@sandbox' && \
    git config --global init.defaultBranch main"

WORKDIR /home/claude/workspace
